rules_version = '2';

// AI GM security rules.
service cloud.firestore {
  match /databases/{database}/documents {

    // Solo cloud games, the cloud character library, and multiplayer
    // memberships all live under the user — only that user may touch them.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Multiplayer games are shared across their members.
    match /games/{gameId} {
      // Members can always read; non-members may read an OPEN lobby so they can join.
      allow read: if request.auth != null
        && (resource.data.status == 'open' || request.auth.uid in resource.data.members);
      // Host creates the game and must list themselves as host + member.
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() <= 6;
      // Any change must leave the editor as a member, capped at 6 (this is how a
      // joiner adds themselves to an open lobby).
      allow update: if request.auth != null
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() <= 6;
      // Only the host may delete the whole game.
      allow delete: if request.auth != null && request.auth.uid == resource.data.hostUid;

      // Subcollections (transcript, wiki, scenes, characters, sheetLog, cp_*):
      // any member of the parent game may read and write.
      match /{sub}/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.members;
      }
    }

    // Lobby code -> gameId pointers. Any signed-in user can resolve a code to
    // join; codes are 4 digits, so this is guessable by design (mitigated by the
    // member cap and host lock). Writes are for host create / cleanup.
    match /lobbies/{code} {
      allow read, write: if request.auth != null;
    }
  }
}
