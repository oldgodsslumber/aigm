rules_version = '2';

// AI GM — every document lives under users/{uid}, so a signed-in user can
// read and write only their own games, library, and packs. Nothing is public.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
